    function populateLanguageOptions() {
      els.languageSelect.innerHTML = Object.entries(LANG_DATA)
        .map(([key, val]) => `<option value="${key}">${val.label}</option>`)
        .join('');
      els.languageSelect.value = state.language;
    }

    function sample(arr) {
      return arr[Math.floor(Math.random() * arr.length)];
    }

    function shuffleClone(arr) {
      const a = [...arr];
      for (let i = a.length - 1; i > 0; i--) {
        const j = Math.floor(Math.random() * (i + 1));
        [a[i], a[j]] = [a[j], a[i]];
      }
      return a;
    }

    function buildPrompt() {
      const lang = LANG_DATA[state.language] || LANG_DATA.malaysian;
      const mode = els.modeSelect.value;
      state.mode = mode;
      const count = Number(els.wordCountSelect.value || 35);

      if (mode === 'words') {
        const words = [];
        const source = lang.words;
        while (words.length < count) {
          words.push(sample(source));
        }
        state.promptWords = words;
        state.promptText = words.join(' ');
      } else if (mode === 'quote') {
        state.promptText = sample(lang.quotes);
        state.promptWords = state.promptText.trim().split(/\s+/);
      } else {
        state.promptText = sample(lang.paragraphs);
        state.promptWords = state.promptText.trim().split(/\s+/);
      }
      renderPrompt();
    }

    function renderPrompt() {
      els.promptBox.innerHTML = state.promptWords
        .map((word, idx) => `<span class="word pending" data-word-index="${idx}">${escapeHtml(word)}</span>`)
        .join(' ');
    }

    function escapeHtml(text) {
      return String(text)
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#039;');
    }

    function getSelectedSeconds() {
      const active = els.timePresetWrap.querySelector('.chip-btn.active');
      const val = active?.dataset?.seconds || '60';
      if (val === 'custom') {
        const custom = Number(els.customSeconds.value || 90);
        return Math.max(5, Math.min(600, custom || 90));
      }
      return Number(val || 60);
    }

    function armTest() {
      state.selectedSeconds = getSelectedSeconds();
      state.secondsLeft = state.selectedSeconds;
      state.startedAt = 0;
      state.finishedAt = 0;
      state.totalDurationMs = 0;
      state.isRunning = false;
      state.isArmed = true;
      state.wordLogs = [];
      state.errors = [];
      state.lastWordCompleteAt = 0;
      if (state.timerId) clearInterval(state.timerId);
      state.timerId = null;
      els.typingInput.value = '';
      els.typingInput.disabled = false;
      els.typingInput.focus();
      els.testStatus.textContent = 'Armed';
      updateLiveStats();
      renderErrors();
      renderWordTimings();
      buildPrompt();
    }

    function startRunningTimer() {
      if (state.isRunning) return;
      state.isRunning = true;
      state.isArmed = false;
      state.startedAt = Date.now();
      state.lastWordCompleteAt = state.startedAt;
      els.testStatus.textContent = 'Running';
      state.timerId = setInterval(() => {
        const elapsedMs = Date.now() - state.startedAt;
        const remaining = Math.max(0, state.selectedSeconds - Math.floor(elapsedMs / 1000));
        state.secondsLeft = remaining;
        updateTimerUI();
        updateLiveStats();
        if (remaining <= 0) {
          finishTest();
        }
      }, 100);
    }

    function updateTimerUI() {
      els.timerDisplay.textContent = String(state.secondsLeft);
      els.statTime.textContent = `${state.secondsLeft}s`;
      const pct = state.selectedSeconds > 0 ? ((state.selectedSeconds - state.secondsLeft) / state.selectedSeconds) * 100 : 0;
      els.progressFill.style.width = `${Math.max(0, Math.min(100, pct))}%`;
    }

    function parseInputWords() {
      const raw = els.typingInput.value.replace(/\n/g, ' ').trimStart();
      if (!raw.trim()) return [];
      return raw.split(/\s+/).filter(Boolean);
    }

    function parseInputWordsRawPreserve() {
      const raw = els.typingInput.value.replace(/\n/g, ' ');
      return raw.split(/\s+/).filter(Boolean);
    }

    function refreshWordHighlights() {
      const inputWords = parseInputWordsRawPreserve();
      const nodes = els.promptBox.querySelectorAll('.word');
      nodes.forEach((node, idx) => {
        node.className = 'word';
        const expected = state.promptWords[idx] || '';
        const typed = inputWords[idx];
        if (typed == null) {
          node.classList.add(idx === inputWords.length ? 'active' : 'pending');
        } else if (typed === expected) {
          node.classList.add('correct');
        } else {
          node.classList.add('wrong');
        }
      });
    }

    function hashErrorsAndWordLogs() {
      const input = els.typingInput.value.replace(/\n/g, ' ');
      const completedWords = input.endsWith(' ') ? input.trim().split(/\s+/).filter(Boolean) : input.trim().split(/\s+/).filter(Boolean).slice(0, -1);
      const now = Date.now();
      while (state.wordLogs.length < completedWords.length) {
        const idx = state.wordLogs.length;
        const typed = completedWords[idx] || '';
        const expected = state.promptWords[idx] || '';
        const wordEndedAt = now;
        const deltaMs = state.startedAt ? wordEndedAt - (state.lastWordCompleteAt || state.startedAt) : 0;
        state.lastWordCompleteAt = wordEndedAt;
        const correct = typed === expected;
        state.wordLogs.push({
          index: idx,
          expected,
          typed,
          correct,
          ms: Math.max(0, deltaMs),
          at: wordEndedAt
        });
        if (!correct) {
          state.errors.push({
            index: idx,
            expected,
            typed,
            ms: Math.max(0, deltaMs),
            at: wordEndedAt
          });
        }
      }
    }

    function calculateMetrics() {
      const typedWords = parseInputWords();
      const elapsedMs = state.isRunning ? Math.max(1, Date.now() - state.startedAt) : Math.max(1, state.totalDurationMs || 1);
      const elapsedMinutes = elapsedMs / 60000;
      const typedChars = els.typingInput.value.length;
      const rawWpm = elapsedMinutes > 0 ? (typedChars / 5) / elapsedMinutes : 0;

      let correctChars = 0;
      let totalExpectedCharsCompared = 0;
      for (let i = 0; i < typedWords.length; i++) {
        const typed = typedWords[i] || '';
        const expected = state.promptWords[i] || '';
        const maxLen = Math.max(typed.length, expected.length);
        totalExpectedCharsCompared += maxLen;
        for (let j = 0; j < maxLen; j++) {
          if ((typed[j] || '') === (expected[j] || '')) correctChars++;
        }
      }
      const accuracy = totalExpectedCharsCompared > 0 ? (correctChars / totalExpectedCharsCompared) * 100 : 100;
      const correctWords = typedWords.filter((w, i) => w === state.promptWords[i]).length;
      const netWpm = elapsedMinutes > 0 ? correctWords / elapsedMinutes : 0;
      const errorCount = typedWords.reduce((n, w, i) => n + (w === state.promptWords[i] ? 0 : 1), 0);

      const timings = state.wordLogs.map(x => x.ms / 1000).filter(Boolean);
      let consistency = 100;
      if (timings.length >= 2) {
        const avg = timings.reduce((a, b) => a + b, 0) / timings.length;
        const variance = timings.reduce((a, b) => a + Math.pow(b - avg, 2), 0) / timings.length;
        const std = Math.sqrt(variance);
        consistency = Math.max(0, 100 - ((std / Math.max(avg, 0.01)) * 100));
      }

      return {
        elapsedMs,
        elapsedMinutes,
        typedChars,
        correctChars,
        accuracy: Number(accuracy.toFixed(2)),
        rawWpm: Number(rawWpm.toFixed(2)),
        netWpm: Number(netWpm.toFixed(2)),
        errorCount,
        correctWords,
        totalWordsTyped: typedWords.length,
        consistency: Number(consistency.toFixed(2))
      };
    }

    function updateLiveStats() {
      updateTimerUI();
      refreshWordHighlights();
      const m = calculateMetrics();
      els.statWpm.textContent = Math.round(m.netWpm);
      els.statRawWpm.textContent = Math.round(m.rawWpm);
      els.statAccuracy.textContent = `${m.accuracy.toFixed(0)}%`;
      els.statErrors.textContent = String(m.errorCount);
      els.statConsistency.textContent = `${m.consistency.toFixed(0)}%`;
      renderErrors();
      renderWordTimings();
    }

    function renderErrors() {
      els.wrongCountBadge.textContent = `${state.errors.length} ${state.errors.length === 1 ? 'error' : 'errors'}`;
      if (!state.errors.length) {
        els.errorTableBody.innerHTML = '<tr><td colspan="5" class="muted" style="padding:18px">No error history yet.</td></tr>';
        return;
      }
      els.errorTableBody.innerHTML = state.errors.map((e, i) => `
        <tr>
          <td>${i + 1}</td>
          <td class="good">${escapeHtml(e.expected)}</td>
          <td class="bad">${escapeHtml(e.typed || '(blank)')}</td>
          <td>${e.index + 1}</td>
          <td>${(e.ms / 1000).toFixed(2)}s</td>
        </tr>
      `).join('');
    }

    function renderWordTimings() {
      els.timingCountBadge.textContent = `${state.wordLogs.length} words`;
      if (!state.wordLogs.length) {
        els.timingList.innerHTML = '<div class="attempt-item muted">No word timing yet.</div>';
        return;
      }
      els.timingList.innerHTML = state.wordLogs.map((w, i) => `
        <div class="row">
          <div class="rank">${i + 1}</div>
          <div>
            <div class="row-name ${w.correct ? 'good' : 'bad'}">${escapeHtml(w.typed || '(blank)')}</div>
            <div class="row-sub">Expected: ${escapeHtml(w.expected)}</div>
          </div>
          <div class="score ${w.correct ? 'good' : 'bad'}">${(w.ms / 1000).toFixed(2)}s</div>
        </div>
      `).join('');
    }

    function finishTest() {
      if (!state.isRunning && !state.isArmed) return;
      if (state.timerId) clearInterval(state.timerId);
      state.timerId = null;
      if (!state.startedAt) state.startedAt = Date.now();
      state.finishedAt = Date.now();
      state.totalDurationMs = Math.max(1, state.finishedAt - state.startedAt);
      state.secondsLeft = 0;
      state.isRunning = false;
      state.isArmed = false;
      els.typingInput.disabled = true;
      els.testStatus.textContent = 'Finished';
      hashErrorsAndWordLogs();
      updateLiveStats();
      saveResult();
    }

    function clearInputOnly() {
      els.typingInput.value = '';
      state.wordLogs = [];
      state.errors = [];
      state.lastWordCompleteAt = state.startedAt || 0;
      renderErrors();
      renderWordTimings();
      refreshWordHighlights();
      updateLiveStats();
      els.typingInput.focus();
    }

    function saveResult() {
      const m = calculateMetrics();
      const emailKey = sanitizeEmailKeepAt(state.user.email || 'guest@example.com');
      const resultRef = db.ref(`typing_results/${emailKey}`).push();
      const payload = {
        name: state.user.name || 'Guest User',
        email: state.user.email || 'guest@example.com',
        photo: state.user.photo || '',
        language: state.language,
        languageLabel: LANG_DATA[state.language]?.label || state.language,
        mode: state.mode,
        durationSeconds: state.selectedSeconds,
        elapsedMs: m.elapsedMs,
        wpm: m.netWpm,
        rawWpm: m.rawWpm,
        accuracy: m.accuracy,
        consistency: m.consistency,
        errors: state.errors.length,
        correctWords: m.correctWords,
        totalWordsTyped: m.totalWordsTyped,
        correctChars: m.correctChars,
        typedChars: m.typedChars,
        wrongWords: state.errors,
        perWordTimings: state.wordLogs,
        promptText: state.promptText,
        createdAt: Date.now()
      };

      resultRef.set(payload).then(() => {
        syncUserAggregate(emailKey, payload);
      }).catch(err => {
        console.error('Failed to save typing result:', err);
      });
    }

    function syncUserAggregate(emailKey, payload) {
      const userRef = db.ref(`typing_users/${emailKey}`);
      userRef.transaction(cur => {
        const next = cur || {
          name: state.user.name || 'Guest User',
          email: state.user.email || 'guest@example.com',
          photo: state.user.photo || '',
          totalTests: 0,
          bestWpm: 0,
          bestAccuracy: 0,
          averageWpm: 0,
          totalWpmSum: 0,
          updatedAt: Date.now(),
          lastLanguage: state.language
        };

        const totalTests = Number(next.totalTests || 0) + 1;
        const totalWpmSum = Number(next.totalWpmSum || 0) + Number(payload.wpm || 0);
        next.name = state.user.name || next.name || 'Guest User';
        next.email = state.user.email || next.email || 'guest@example.com';
        next.photo = state.user.photo || next.photo || '';
        next.totalTests = totalTests;
        next.totalWpmSum = totalWpmSum;
        next.averageWpm = totalTests > 0 ? Number((totalWpmSum / totalTests).toFixed(2)) : 0;
        next.bestWpm = Math.max(Number(next.bestWpm || 0), Number(payload.wpm || 0));
        next.bestAccuracy = Math.max(Number(next.bestAccuracy || 0), Number(payload.accuracy || 0));
        next.updatedAt = Date.now();
        next.lastLanguage = state.language;
        return next;
      });
    }

    function listenLeaderboard() {
      db.ref('typing_users').on('value', snap => {
        const val = snap.val() || {};
        const rows = Object.entries(val).map(([key, user]) => ({ key, ...user }));
        state.currentLeaderboard = rows.sort((a, b) => Number(b.bestWpm || 0) - Number(a.bestWpm || 0));
        renderLeaderboard();
        renderTestsTaken();
        syncUserSummary();
