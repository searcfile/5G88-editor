        <div class="row">
          <div class="rank">${idx + 1}</div>
          <div class="name-line">
            <img class="small-avatar" src="${user.photo || `data:image/svg+xml;utf8,${encodeURIComponent(`<svg xmlns='http://www.w3.org/2000/svg' width='60' height='60'><defs><linearGradient id='g' x1='0' y1='0' x2='1' y2='1'><stop offset='0%' stop-color='#f4b63f'/><stop offset='100%' stop-color='#ffcc67'/></linearGradient></defs><rect width='100%' height='100%' rx='30' fill='url(#g)'/><text x='50%' y='56%' dominant-baseline='middle' text-anchor='middle' font-family='Arial' font-size='24' font-weight='700' fill='#111'>${avatarInitial(user.name)}</text></svg>`)}" alt="avatar">
            <div style="min-width:0">
              <div class="row-name">${escapeHtml(user.name || 'Unknown User')}</div>
              <div class="row-sub">Best ${Number(user.bestWpm || 0).toFixed(0)} WPM · ${Number(user.bestAccuracy || 0).toFixed(0)}%</div>
            </div>
          </div>
          <div class="score">${Number(user.totalTests || 0)}</div>
        </div>
      `).join('');
    }

    function listenMyAttempts() {
      if (!state.user?.email) return;
      const key = sanitizeEmailKeepAt(state.user.email);
      db.ref(`typing_results/${key}`).limitToLast(20).on('value', snap => {
        const val = snap.val() || {};
        const rows = Object.entries(val)
          .map(([id, data]) => ({ id, ...data }))
          .sort((a, b) => Number(b.createdAt || 0) - Number(a.createdAt || 0));
        state.myAttempts = rows;
        renderMyAttempts();
      });
    }

    function renderMyAttempts() {
      els.myAttemptBadge.textContent = `${state.myAttempts.length} records`;
      if (!state.myAttempts.length) {
        els.myAttemptsList.innerHTML = '<div class="attempt-item muted">No test history yet.</div>';
        return;
      }
      els.myAttemptsList.innerHTML = state.myAttempts.map(item => `
        <div class="attempt-item">
          <div class="attempt-top">
            <div>
              <div style="font-weight:800">${escapeHtml(item.languageLabel || item.language || 'Unknown')}</div>
              <div class="row-sub">${escapeHtml(item.mode || 'mode')} · ${Number(item.durationSeconds || 0)}s · ${new Date(Number(item.createdAt || 0)).toLocaleString()}</div>
            </div>
            <div style="display:flex;gap:8px;flex-wrap:wrap">
              <span class="pill">WPM ${Number(item.wpm || 0).toFixed(0)}</span>
              <span class="pill">Acc ${Number(item.accuracy || 0).toFixed(0)}%</span>
              <span class="pill">Errors ${Number(item.errors || 0)}</span>
            </div>
          </div>
        </div>
      `).join('');
    }

    function syncUserSummary() {
      const myKey = sanitizeEmailKeepAt(state.user.email || '');
      const me = state.currentLeaderboard.find(x => x.key === myKey);
      if (me) {
        els.myBestWpm.textContent = Number(me.bestWpm || 0).toFixed(0);
        els.myBestAccuracy.textContent = `${Number(me.bestAccuracy || 0).toFixed(0)}%`;
        els.myTotalTests.textContent = Number(me.totalTests || 0).toFixed(0);
        els.myAverageWpm.textContent = Number(me.averageWpm || 0).toFixed(0);
        const rank = state.currentLeaderboard.findIndex(x => x.key === myKey);
        els.myRankBadge.textContent = rank >= 0 ? `Rank #${rank + 1}` : 'Unranked';
      } else {
        els.myBestWpm.textContent = '0';
        els.myBestAccuracy.textContent = '0%';
        els.myTotalTests.textContent = '0';
        els.myAverageWpm.textContent = '0';
        els.myRankBadge.textContent = 'Unranked';
      }
    }

    function bindEvents() {
      els.languageSelect.addEventListener('change', () => {
        state.language = els.languageSelect.value;
        armTest();
      });
      els.modeSelect.addEventListener('change', armTest);
      els.wordCountSelect.addEventListener('change', armTest);
      els.startBtn.addEventListener('click', armTest);
      els.restartBtn.addEventListener('click', armTest);
      els.clearBtn.addEventListener('click', clearInputOnly);
      els.finishBtn.addEventListener('click', finishTest);

      els.timePresetWrap.addEventListener('click', (e) => {
        const btn = e.target.closest('.chip-btn');
        if (!btn) return;
        [...els.timePresetWrap.querySelectorAll('.chip-btn')].forEach(x => x.classList.remove('active'));
        btn.classList.add('active');
        armTest();
      });

      els.typingInput.addEventListener('input', () => {
        if (!state.isRunning && state.isArmed && els.typingInput.value.trim()) {
          startRunningTimer();
        }
        if (state.isRunning) {
          hashErrorsAndWordLogs();
        }
        updateLiveStats();
      });

      els.typingInput.addEventListener('keydown', (e) => {
        if (e.key === 'Enter') {
          e.preventDefault();
        }
      });
    }

    function init() {
      populateLanguageOptions();
      bindEvents();
      readLoginFromStorage();
      askParentForLogin();
      syncUserUI();
      listenLeaderboard();
      armTest();
    }

    init();
  </script>
</body>
</html>
