<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Typing Test Leaderboard</title>
  <style>
    :root{
      --bg:#07111d;
      --panel:#0d1827;
      --panel-2:#122033;
      --line:rgba(255,255,255,.08);
      --text:#eaf2ff;
      --muted:#9db0c9;
      --gold:#f4b63f;
      --gold-2:#ffcc67;
      --green:#2fd67b;
      --red:#ff6b6b;
      --blue:#4da3ff;
      --shadow:0 14px 40px rgba(0,0,0,.35);
      --radius:18px;
    }

    *{box-sizing:border-box}
    html,body{height:100%}
    body{
      margin:0;
      font-family:Inter,Segoe UI,Arial,sans-serif;
      background:
        radial-gradient(circle at top left, rgba(244,182,63,.08), transparent 24%),
        radial-gradient(circle at top right, rgba(77,163,255,.08), transparent 22%),
        linear-gradient(180deg,#08111b,#06101b 35%,#07111d 100%);
      color:var(--text);
    }

    .page{
      max-width:1700px;
      margin:0 auto;
      padding:18px;
      display:grid;
      grid-template-columns: 1.25fr .9fr;
      gap:18px;
      min-height:100vh;
    }

    .card{
      background:linear-gradient(180deg,rgba(255,255,255,.03),rgba(255,255,255,.015));
      border:1px solid var(--line);
      border-radius:var(--radius);
      box-shadow:var(--shadow);
      overflow:hidden;
      min-width:0;
      backdrop-filter: blur(10px);
    }

    .left-col,.right-col{display:flex;flex-direction:column;gap:18px;min-width:0}

    .header{
      padding:18px 20px;
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap:16px;
      border-bottom:1px solid var(--line);
      background:linear-gradient(180deg,rgba(255,255,255,.04),rgba(255,255,255,.01));
    }
    .title-wrap{display:flex;align-items:center;gap:14px;min-width:0}
    .logo{
      width:48px;height:48px;border-radius:14px;
      display:grid;place-items:center;
      color:#111;
      background:linear-gradient(135deg,var(--gold),var(--gold-2));
      font-weight:900;font-size:20px;flex:0 0 auto;
      box-shadow:0 8px 24px rgba(244,182,63,.28);
    }
    h1,h2,h3,p{margin:0}
    .title{font-size:26px;font-weight:800;letter-spacing:.3px}
    .sub{color:var(--muted);font-size:13px;margin-top:4px}

    .user-chip{
      display:flex;align-items:center;gap:12px;min-width:0;
      padding:10px 12px;border:1px solid var(--line);border-radius:16px;
      background:rgba(255,255,255,.03);
    }
    .avatar{width:42px;height:42px;border-radius:50%;object-fit:cover;background:#1b2a40;border:1px solid var(--line)}
    .avatar.fallback{display:grid;place-items:center;font-weight:800;color:#111;background:linear-gradient(135deg,var(--gold),var(--gold-2))}
    .user-meta{min-width:0}
    .user-name{font-weight:700;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
    .user-email{font-size:12px;color:var(--muted);white-space:nowrap;overflow:hidden;text-overflow:ellipsis}

    .section{padding:18px}
    .controls{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:12px}
    .field{display:flex;flex-direction:column;gap:8px}
    .label{font-size:12px;font-weight:700;color:var(--muted);letter-spacing:.3px}
    select,input,button,textarea{
      font:inherit;
    }
    select,input,textarea{
      width:100%;
      background:#0b1422;
      color:var(--text);
      border:1px solid var(--line);
      border-radius:14px;
      padding:12px 14px;
      outline:none;
    }
    select:focus,input:focus,textarea:focus{border-color:rgba(244,182,63,.55);box-shadow:0 0 0 3px rgba(244,182,63,.12)}

    .mode-row{display:flex;gap:8px;flex-wrap:wrap}
    .chip-btn,.btn{
      border:none;cursor:pointer;
      border-radius:14px;
      padding:11px 14px;
      background:#132132;
      color:var(--text);
      border:1px solid var(--line);
      transition:.18s ease;
    }
    .chip-btn:hover,.btn:hover{transform:translateY(-1px);border-color:rgba(244,182,63,.35)}
    .chip-btn.active{background:linear-gradient(135deg,var(--gold),var(--gold-2));color:#111;font-weight:800;border-color:transparent}
    .btn.primary{background:linear-gradient(135deg,var(--gold),var(--gold-2));color:#111;font-weight:800;border-color:transparent}
    .btn.success{background:linear-gradient(135deg,#33d17a,#7ff2ad);color:#092014;font-weight:800;border-color:transparent}
    .btn.ghost{background:#0b1422}
    .btn.danger{background:linear-gradient(135deg,#ff6b6b,#ff9b9b);color:#2c0d0d;font-weight:800;border-color:transparent}
    .action-row{display:flex;gap:10px;flex-wrap:wrap}

    .stats-grid{
      display:grid;
      grid-template-columns:repeat(6,minmax(0,1fr));
      gap:12px;
      margin-top:16px;
    }
    .stat{
      padding:14px;border-radius:16px;border:1px solid var(--line);
      background:rgba(255,255,255,.025);
      min-width:0;
    }
    .stat .k{font-size:12px;color:var(--muted);font-weight:700;text-transform:uppercase;letter-spacing:.4px}
    .stat .v{font-size:28px;font-weight:800;margin-top:8px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}

    .prompt-wrap{padding:18px;border-top:1px solid var(--line)}
    .progress-bar{height:10px;border-radius:999px;background:#0a1320;border:1px solid var(--line);overflow:hidden}
    .progress-fill{height:100%;width:0%;background:linear-gradient(90deg,var(--gold),var(--gold-2),#fff0c2);transition:width .15s ease}
    .prompt-toolbar{display:flex;justify-content:space-between;gap:12px;align-items:center;margin-bottom:14px;flex-wrap:wrap}
    .timer{
      display:flex;align-items:center;gap:10px;
      font-weight:900;font-size:28px;
      color:var(--gold-2);
    }
    .timer small{font-size:13px;color:var(--muted);font-weight:700}
    .prompt-box{
      min-height:140px;max-height:220px;overflow:auto;
      background:#09121e;border:1px solid var(--line);border-radius:18px;padding:18px;
      line-height:1.95;font-size:24px;letter-spacing:.2px;
    }
    .word{padding:2px 4px;border-radius:8px;transition:background .12s ease,color .12s ease}
    .word.active{background:rgba(77,163,255,.16)}
    .word.correct{color:#baf9d4}
    .word.wrong{color:#ffc2c2;background:rgba(255,107,107,.09)}
    .word.pending{color:#d8e4f8}

    .typing-area{padding:18px;border-top:1px solid var(--line)}
    #typingInput{
      min-height:115px;resize:vertical;
      font-size:20px;line-height:1.7;background:#08101a;
    }
    .help{color:var(--muted);font-size:12px;margin-top:8px}

    .split-2{display:grid;grid-template-columns:1fr 1fr;gap:18px;padding:18px;border-top:1px solid var(--line)}
    .mini-card{border:1px solid var(--line);background:rgba(255,255,255,.02);border-radius:16px;overflow:hidden}
    .mini-head{padding:14px 16px;border-bottom:1px solid var(--line);display:flex;justify-content:space-between;align-items:center;gap:10px}
    .mini-title{font-weight:800}
    .mini-body{padding:0}
    .list{max-height:360px;overflow:auto}
    .row{
      display:grid;
      grid-template-columns: 44px 1fr auto;
      gap:10px;align-items:center;
      padding:12px 16px;border-bottom:1px solid rgba(255,255,255,.05)
    }
    .row:last-child{border-bottom:none}
    .rank{font-weight:900;color:var(--muted);text-align:center}
    .name-line{display:flex;align-items:center;gap:10px;min-width:0}
    .small-avatar{width:34px;height:34px;border-radius:50%;object-fit:cover;background:#17263b;border:1px solid var(--line)}
    .row-name{white-space:nowrap;overflow:hidden;text-overflow:ellipsis;font-weight:700}
    .row-sub{font-size:12px;color:var(--muted);margin-top:2px}
    .score{font-weight:900}

    .bad{color:var(--red)}
    .good{color:var(--green)}
    .warn{color:var(--gold-2)}
    .muted{color:var(--muted)}

    .error-table{width:100%;border-collapse:collapse}
    .error-table th,.error-table td{padding:12px 14px;border-bottom:1px solid rgba(255,255,255,.05);text-align:left;font-size:14px;vertical-align:top}
    .error-table th{font-size:12px;color:var(--muted);text-transform:uppercase;letter-spacing:.45px}

    .history-grid{display:grid;grid-template-columns:1fr;gap:18px;padding:18px;border-top:1px solid var(--line)}
    .attempt-item{padding:14px 16px;border-bottom:1px solid rgba(255,255,255,.05)}
    .attempt-top{display:flex;justify-content:space-between;gap:12px;align-items:flex-start;flex-wrap:wrap}
    .pill{padding:6px 10px;border-radius:999px;border:1px solid var(--line);font-size:12px;color:var(--muted);background:rgba(255,255,255,.03)}

    .footer-note{padding:14px 18px;border-top:1px solid var(--line);font-size:12px;color:var(--muted)}

    @media (max-width: 1200px){
      .page{grid-template-columns:1fr}
      .stats-grid{grid-template-columns:repeat(3,minmax(0,1fr))}
      .controls{grid-template-columns:repeat(2,minmax(0,1fr))}
      .split-2{grid-template-columns:1fr}
    }
    @media (max-width: 700px){
      .page{padding:10px}
      .header{padding:14px}
      .section,.prompt-wrap,.typing-area,.split-2,.history-grid{padding:14px}
      .controls{grid-template-columns:1fr}
      .stats-grid{grid-template-columns:repeat(2,minmax(0,1fr))}
      .title{font-size:21px}
      .prompt-box{font-size:20px;line-height:1.8}
      .timer{font-size:24px}
    }
  </style>
</head>
<body>
  <div class="page">
    <div class="left-col">
      <section class="card">
        <div class="header">
          <div class="title-wrap">
            <div class="logo">TT</div>
            <div>
              <h1 class="title">Typing Test Arena</h1>
              <p class="sub">Realtime typing test with countdown, accuracy, typo history, word timings, and leaderboard.</p>
            </div>
          </div>

          <div class="user-chip">
            <img id="userAvatar" class="avatar" alt="avatar" />
            <div class="user-meta">
              <div id="userName" class="user-name">Guest User</div>
              <div id="userEmail" class="user-email">guest@example.com</div>
            </div>
          </div>
        </div>

        <div class="section">
          <div class="controls">
            <div class="field">
              <div class="label">Language</div>
              <select id="languageSelect"></select>
            </div>

            <div class="field">
              <div class="label">Mode</div>
              <select id="modeSelect">
                <option value="words">Random Words</option>
                <option value="quote">Quote</option>
                <option value="paragraph">Paragraph</option>
              </select>
            </div>

            <div class="field">
              <div class="label">Word Count</div>
              <select id="wordCountSelect">
                <option value="20">20 words</option>
                <option value="35" selected>35 words</option>
                <option value="50">50 words</option>
                <option value="80">80 words</option>
              </select>
            </div>

            <div class="field">
              <div class="label">Custom Seconds</div>
              <input id="customSeconds" type="number" min="5" max="600" value="90" placeholder="90" />
            </div>
          </div>

          <div style="height:14px"></div>

          <div class="field">
            <div class="label">Countdown</div>
            <div class="mode-row" id="timePresetWrap">
              <button class="chip-btn" data-seconds="15">15s</button>
              <button class="chip-btn" data-seconds="30">30s</button>
              <button class="chip-btn active" data-seconds="60">60s</button>
              <button class="chip-btn" data-seconds="120">120s</button>
              <button class="chip-btn" data-seconds="custom">Custom</button>
            </div>
          </div>

          <div style="height:14px"></div>

          <div class="action-row">
            <button id="startBtn" class="btn primary">Start Test</button>
            <button id="restartBtn" class="btn success">Restart</button>
            <button id="clearBtn" class="btn ghost">Clear Input</button>
            <button id="finishBtn" class="btn danger">Finish Now</button>
          </div>

          <div class="stats-grid">
            <div class="stat"><div class="k">Time Left</div><div class="v" id="statTime">60s</div></div>
            <div class="stat"><div class="k">WPM</div><div class="v" id="statWpm">0</div></div>
            <div class="stat"><div class="k">Raw WPM</div><div class="v" id="statRawWpm">0</div></div>
            <div class="stat"><div class="k">Accuracy</div><div class="v" id="statAccuracy">100%</div></div>
            <div class="stat"><div class="k">Errors</div><div class="v" id="statErrors">0</div></div>
            <div class="stat"><div class="k">Consistency</div><div class="v" id="statConsistency">100%</div></div>
          </div>
        </div>

        <div class="prompt-wrap">
          <div class="prompt-toolbar">
            <div style="display:flex;align-items:center;gap:12px;flex-wrap:wrap">
              <div class="timer"><span id="timerDisplay">60</span> <small>seconds left</small></div>
              <span id="testStatus" class="pill">Ready</span>
            </div>
            <div style="min-width:260px;flex:1;max-width:420px">
              <div class="progress-bar"><div id="progressFill" class="progress-fill"></div></div>
            </div>
          </div>
          <div id="promptBox" class="prompt-box"></div>
        </div>

        <div class="typing-area">
          <textarea id="typingInput" placeholder="Press Start Test, then begin typing here..."></textarea>
          <div class="help">Press space after each word. Timer starts automatically on first typing if test is armed. Results save to realtime leaderboard using the logged-in user from your main page.</div>
        </div>

        <div class="split-2">
          <div class="mini-card">
            <div class="mini-head">
              <div class="mini-title">Wrong Word History</div>
              <span id="wrongCountBadge" class="pill">0 errors</span>
            </div>
            <div class="mini-body" style="max-height:360px;overflow:auto">
              <table class="error-table">
                <thead>
                  <tr>
                    <th>#</th>
                    <th>Expected</th>
                    <th>Typed</th>
                    <th>Word No</th>
                    <th>Time</th>
                  </tr>
                </thead>
                <tbody id="errorTableBody">
                  <tr><td colspan="5" class="muted" style="padding:18px">No error history yet.</td></tr>
                </tbody>
              </table>
            </div>
          </div>

          <div class="mini-card">
            <div class="mini-head">
              <div class="mini-title">Per Word Timing</div>
              <span id="timingCountBadge" class="pill">0 words</span>
            </div>
            <div id="timingList" class="list">
              <div class="attempt-item muted">No word timing yet.</div>
            </div>
          </div>
        </div>

        <div class="history-grid">
          <div class="mini-card">
            <div class="mini-head">
              <div class="mini-title">My Recent Attempts</div>
              <span id="myAttemptBadge" class="pill">0 records</span>
            </div>
            <div id="myAttemptsList" class="list">
              <div class="attempt-item muted">No test history yet.</div>
            </div>
          </div>
        </div>

        <div class="footer-note">
          Uses login from parent main page or localStorage <code>gmailLogin</code>. If page runs in iframe, parent can send <code>{ type: 'user-login', user: {...} }</code> and this page will sync automatically.
        </div>
      </section>
    </div>

    <div class="right-col">
      <section class="card mini-card" style="overflow:hidden">
        <div class="mini-head">
          <div>
            <div class="mini-title">WPM Ranking</div>
            <div class="row-sub">Global leaderboard by best WPM</div>
          </div>
          <span id="leaderboardBadge" class="pill">0 users</span>
        </div>
        <div id="leaderboardList" class="list">
          <div class="attempt-item muted">No leaderboard data yet.</div>
        </div>
      </section>

      <section class="card mini-card" style="overflow:hidden">
        <div class="mini-head">
          <div>
            <div class="mini-title">Tests Taken</div>
            <div class="row-sub">Users with the most completed tests</div>
          </div>
          <span id="takenBadge" class="pill">0 users</span>
        </div>
        <div id="testsTakenList" class="list">
          <div class="attempt-item muted">No test count data yet.</div>
        </div>
      </section>

      <section class="card mini-card" style="overflow:hidden">
        <div class="mini-head">
          <div>
            <div class="mini-title">Live Session Summary</div>
            <div class="row-sub">Current user rank and best stats</div>
          </div>
          <span id="myRankBadge" class="pill">Unranked</span>
        </div>
        <div class="section" id="profileSummary">
          <div class="stats-grid" style="grid-template-columns:repeat(2,minmax(0,1fr));margin-top:0">
            <div class="stat"><div class="k">My Best WPM</div><div class="v" id="myBestWpm">0</div></div>
            <div class="stat"><div class="k">My Best Accuracy</div><div class="v" id="myBestAccuracy">0%</div></div>
            <div class="stat"><div class="k">My Total Tests</div><div class="v" id="myTotalTests">0</div></div>
            <div class="stat"><div class="k">My Average WPM</div><div class="v" id="myAverageWpm">0</div></div>
          </div>
        </div>
      </section>
    </div>
  </div>

