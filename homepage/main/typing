    window.addEventListener('message', (event) => {
      const data = event.data || {};
      if (data.type === 'user-login' && data.user) {
        applyUser(data.user);
      }
      if (data.type === 'theme-change' && data.theme) {
        document.body.dataset.theme = data.theme;
      }
    });

    function askParentForLogin() {
      try {
        window.parent?.postMessage({ type: 'typing-page-ready', wants: 'user-login' }, '*');
