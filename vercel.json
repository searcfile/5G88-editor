{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Permissions-Policy", "value": "clipboard-write=*" },
        { "key": "Cross-Origin-Embedder-Policy", "value": "unsafe-none" },
        { "key": "Cross-Origin-Opener-Policy", "value": "same-origin-allow-popups" },
        { "key": "Cross-Origin-Resource-Policy", "value": "cross-origin" }
      ]
    }
  ],
  "cleanUrls": true,
  "rewrites": [
    { "source": "/main", "destination": "/homepage/main/index.html" },
    { "source": "/login", "destination": "/homepage/login/index.html" },

    { "source": "/main/918kiss", "destination": "/homepage/main/918kiss/index.html" },
    { "source": "/main/evo888", "destination": "/homepage/main/evo888/index.html" },
    { "source": "/main/findgame", "destination": "/homepage/main/findgame/index.html" },
    { "source": "/main/pussy888", "destination": "/homepage/main/pussy888/index.html" },
    { "source": "/main/item", "destination": "/homepage/main/item/index.html" }
  ]
}
