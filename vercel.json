{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Permissions-Policy", "value": "clipboard-write=*" },
        { "key": "Cross-Origin-Embedder-Policy", "value": "unsafe-none" },
        { "key": "Cross-Origin-Opener-Policy", "value": "same-origin-allow-popups" },
        { "key": "Cross-Origin-Resource-Policy", "value": "cross-origin" }
      ]
    }
  ],
  "cleanUrls": true,
  "rewrites": [
    { "source": "/login", "destination": "/homepage/login/index.html" },

    { "source": "/main/index.html", "destination": "/homepage/main/index.html" },
    { "source": "/main/main.js", "destination": "/homepage/main/main.js" },
    { "source": "/main/page.css", "destination": "/homepage/main/page.css" },
    { "source": "/main/logo.svg", "destination": "/homepage/main/logo.svg" },

    { "source": "/main/merrychristmas/:path*", "destination": "/homepage/main/merrychristmas/:path*" },
    { "source": "/main/audio/:path*", "destination": "/homepage/main/audio/:path*" },
    { "source": "/main/cimbclick/:path*", "destination": "/homepage/main/cimbclick/:path*" },
    { "source": "/main/item/:path*", "destination": "/homepage/main/item/:path*" },
    { "source": "/main/livechat/:path*", "destination": "/homepage/main/livechat/:path*" },
    { "source": "/main/rhbbank/:path*", "destination": "/homepage/main/rhbbank/:path*" },
    { "source": "/main/bankislam/:path*", "destination": "/homepage/main/bankislam/:path*" },
    { "source": "/main/918kiss/:path*", "destination": "/homepage/main/918kiss/:path*" },
    { "source": "/main/evo888/:path*", "destination": "/homepage/main/evo888/:path*" },
    { "source": "/main/findgame/:path*", "destination": "/homepage/main/findgame/:path*" },
    { "source": "/main/linkdownload/:path*", "destination": "/homepage/main/linkdownload/:path*" },
    { "source": "/main/logogame/:path*", "destination": "/homepage/main/logogame/:path*" },
    { "source": "/main/maybank/:path*", "destination": "/homepage/main/maybank/:path*" },
    { "source": "/main/maybank2u/:path*", "destination": "/homepage/main/maybank2u/:path*" },
    { "source": "/main/mega888/:path*", "destination": "/homepage/main/mega888/:path*" },
    { "source": "/main/pussy888/:path*", "destination": "/homepage/main/pussy888/:path*" },
    { "source": "/main/scr888h5/:path*", "destination": "/homepage/main/scr888h5/:path*" },
    { "source": "/main/tipsgenerate/:path*", "destination": "/homepage/main/tipsgenerate/:path*" },

